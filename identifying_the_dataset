        "import os\n",
        "import cv2\n",
        "\n",
        "extract_to = \"/content/shoplifting_data\"\n",
        "\n",
        "paths = [\n",
        "    (\"/content/shoplifting_data/shoplifting/shoplifting\", \"shoplifting\"),\n",
        "    (\"/content/shoplifting_data/shoplifting/normal\", \"normal\"),\n",
        "    (\"/content/shoplifting_data/shoplifting_1/Shop DataSet/shop lifters\", \"shoplifters\"),\n",
        "    (\"/content/shoplifting_data/shoplifting_1/Shop DataSet/non shop lifters\", \"non_shoplifters\"),\n",
        "]\n",
        "\n",
        "for folder_path, label in paths:\n",
        "    durations = []\n",
        "    files = [f for f in os.listdir(folder_path) if f.endswith('.mp4')][:10]\n",
        "    for f in files:\n",
        "        cap = cv2.VideoCapture(os.path.join(folder_path, f))\n",
        "        fps = cap.get(cv2.CAP_PROP_FPS)\n",
        "        frames = cap.get(cv2.CAP_PROP_FRAME_COUNT)\n",
        "        if fps > 0:\n",
        "            durations.append(frames / fps)\n",
        "        cap.release()\n",
        "\n",
        "    if durations:\n",
        "        print(f\"{label}:\")\n",
        "        print(f\"  Avg duration: {sum(durations)/len(durations):.1f}s\")\n",
        "        print(f\"  Min: {min(durations):.1f}s  Max: {max(durations):.1f}s\\n\")"
      ],
