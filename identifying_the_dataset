        "import os\n",
        "\n",
        "extract_to = \"/content/shoplifting_data\"\n",
        "\n",
        "# Deep scan for videos and images\n",
        "video_ext = ('.mp4', '.avi', '.mov', '.mkv', '.MP4', '.AVI', '.MOV')\n",
        "image_ext = ('.jpg', '.jpeg', '.png', '.JPG', '.PNG')\n",
        "\n",
        "for dataset in ['shoplifting', 'shoplifting_1']:\n",
        "    dataset_path = os.path.join(extract_to, dataset)\n",
        "    print(f\"\\n=== {dataset} ===\")\n",
        "\n",
        "    total_videos = 0\n",
        "    total_images = 0\n",
        "\n",
        "    for dirpath, dirnames, filenames in os.walk(dataset_path):\n",
        "        videos = [f for f in filenames if f.endswith(video_ext)]\n",
        "        images = [f for f in filenames if f.endswith(image_ext)]\n",
        "\n",
        "        if videos or images:\n",
        "            rel_path = os.path.relpath(dirpath, dataset_path)\n",
        "            print(f\"\\n  Folder: {rel_path}\")\n",
        "            print(f\"  Videos: {len(videos)}\")\n",
        "            print(f\"  Images: {len(images)}\")\n",
        "            if videos:\n",
        "                print(f\"  Sample: {videos[:2]}\")\n",
        "\n",
        "        total_videos += len(videos)\n",
        "        total_images += len(images)\n",
        "\n",
        "    print(f\"\\n  TOTAL VIDEOS: {total_videos}\")\n",
        "    print(f\"  TOTAL IMAGES: {total_images}\")"
      ],
